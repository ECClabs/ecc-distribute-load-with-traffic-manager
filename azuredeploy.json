{
    "$schema": "https://schema.management.azure.com/schemas/2015-01-01/deploymentTemplate.json#",
    "contentVersion": "1.0.0.0",
    "parameters": {
        "username": {
            "type": "string",
            "defaultValue": "azureuser"
        },
        "password": {
            "type": "securestring"
        }
    },
    "variables": {
        "deploymentUrl": "[deployment().properties.templateLink.uri]",
        "northeuropeVnetName": "northeurope-vnet",
        "northeuropeVnetAddressPrefix": "10.1.0.0/16",
        "northeuropeVnetResourceId": "[resourceId('Microsoft.Network/virtualNetworks', variables('northeuropeVnetName'))]",
        "northeuropeNSGName": "northeurope-nsg",
        "northeuropeNSGResourceId": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('northeuropeNSGName'))]",
        "northeuropeVMName": "northeurope-vm",
        "northeuropeVMNicName": "northeurope-vm-nic",
        "northeuropeVMNicPIPName": "northeurope-vm-nic-pip",
        "northeuropeSubnetName": "northeurope-subnet",
        "northeuropeSubnetPrefix": "10.1.0.0/24",
        "northeuropeVMDNSName": "[concat(variables('northeuropeVMName'), '-', uniqueString(resourceGroup().id))]",
        "northeuropeVMNicResourceId": "[resourceId('Microsoft.Network/networkInterfaces', variables('northeuropeVMNicName'))]",
        "northeuropeVMNicPIPResourceId": "[resourceId('Microsoft.Network/publicIPAddresses', variables('northeuropeVMNicPIPName'))]",
        "northeuropeSubnetResourceId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('northeuropeVnetName'), variables('northeuropeSubnetName'))]",
        "eastus2VnetName": "eastus2-vnet",
        "eastus2VnetAddressPrefix": "10.2.0.0/16",
        "eastus2VnetResourceId": "[resourceId('Microsoft.Network/virtualNetworks', variables('eastus2VnetName'))]",
        "eastus2NSGName": "eastus2-nsg",
        "eastus2NSGResourceId": "[resourceId('Microsoft.Network/networkSecurityGroups', variables('eastus2NSGName'))]",
        "eastus2VMName": "eastus2-vm",
        "eastus2VMNicName": "eastus2-vm-nic",
        "eastus2VMNicPIPName": "eastus2-vm-nic-pip",
        "eastus2SubnetName": "eastus2-subnet",
        "eastus2SubnetPrefix": "10.2.0.0/24",
        "eastus2VMDNSName": "[concat(variables('eastus2VMName'), '-', uniqueString(resourceGroup().id))]",
        "eastus2VMNicResourceId": "[resourceId('Microsoft.Network/networkInterfaces', variables('eastus2VMNicName'))]",
        "eastus2VMNicPIPResourceId": "[resourceId('Microsoft.Network/publicIPAddresses', variables('eastus2VMNicPIPName'))]",
        "eastus2SubnetResourceId": "[resourceId('Microsoft.Network/virtualNetworks/subnets', variables('eastus2VnetName'), variables('eastus2SubnetName'))]"
    },
    "resources": [
        {
            "type": "Microsoft.Network/networkSecurityGroups",
            "name": "[variables('northeuropeNSGName')]",
            "apiVersion": "2018-08-01",
            "location": "northeurope",
            "properties": {
                "securityRules": [
                    {
                        "name": "http",
                        "properties": {
                            "protocol": "Tcp",
                            "sourcePortRange": "*",
                            "destinationPortRange": "80",
                            "sourceAddressPrefix": "*",
                            "destinationAddressPrefix": "*",
                            "access": "Allow",
                            "priority": 300,
                            "direction": "Inbound"
                        }
                    }
                ]
            },
            "dependsOn": []
        },
        {
            "type": "Microsoft.Network/networkSecurityGroups",
            "name": "[variables('eastus2NSGName')]",
            "apiVersion": "2018-08-01",
            "location": "eastus2",
            "properties": {
                "securityRules": [
                    {
                        "name": "http",
                        "properties": {
                            "protocol": "Tcp",
                            "sourcePortRange": "*",
                            "destinationPortRange": "80",
                            "sourceAddressPrefix": "*",
                            "destinationAddressPrefix": "*",
                            "access": "Allow",
                            "priority": 300,
                            "direction": "Inbound"
                        }
                    }
                ]
            },
            "dependsOn": []
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "name": "[variables('northeuropeVnetName')]",
            "apiVersion": "2018-08-01",
            "location": "northeurope",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "[variables('northeuropeVnetAddressPrefix')]"
                    ]
                },
                "subnets": [
                    {
                        "name": "[variables('northeuropeSubnetName')]",
                        "properties": {
                            "addressPrefix": "[variables('northeuropeSubnetPrefix')]"
                        }
                    }
                ]
            },
            "dependsOn": []
        },
        {
            "type": "Microsoft.Network/virtualNetworks",
            "name": "[variables('eastus2VnetName')]",
            "apiVersion": "2018-08-01",
            "location": "eastus2",
            "properties": {
                "addressSpace": {
                    "addressPrefixes": [
                        "[variables('eastus2VnetAddressPrefix')]"
                    ]
                },
                "subnets": [
                    {
                        "name": "[variables('eastus2SubnetName')]",
                        "properties": {
                            "addressPrefix": "[variables('eastus2SubnetPrefix')]"
                        }
                    }
                ]
            },
            "dependsOn": []
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "sku": {
                "name": "Basic",
                "tier": "Regional"
            },
            "name": "[variables('northeuropeVMNicPIPName')]",
            "apiVersion": "2018-08-01",
            "location": "northeurope",
            "properties": {
                "publicIPAddressVersion": "IPv4",
                "publicIPAllocationMethod": "Static",
                "dnsSettings": {
                    "domainNameLabel": "[variables('northeuropeVMDNSName')]"
                }
            },
            "dependsOn": []
        },
        {
            "type": "Microsoft.Network/publicIPAddresses",
            "sku": {
                "name": "Basic",
                "tier": "Regional"
            },
            "name": "[variables('eastus2VMNicPIPName')]",
            "apiVersion": "2018-08-01",
            "location": "eastus2",
            "properties": {
                "publicIPAddressVersion": "IPv4",
                "publicIPAllocationMethod": "Static",
                "dnsSettings":{
                    "domainNameLabel": "[variables('eastus2VMDNSName')]"
                }
            },
            "dependsOn": []
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "name": "[variables('northeuropeVMNicName')]",
            "apiVersion": "2018-08-01",
            "location": "northeurope",
            "scale": null,
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipconfig1",
                        "properties": {
                            "privateIPAddress": "10.1.0.4",
                            "privateIPAllocationMethod": "Static",
                            "publicIPAddress": {
                                "id": "[variables('northeuropeVMNicPIPResourceId')]"
                            },
                            "subnet": {
                                "id": "[variables('northeuropeSubnetResourceId')]"
                            },
                            "primary": true,
                            "privateIPAddressVersion": "IPv4"
                        }
                    }
                ],
                "enableAcceleratedNetworking": false,
                "enableIPForwarding": false,
                "primary": true,
                "networkSecurityGroup": {
                    "id": "[variables('northeuropeNSGResourceId')]"
                }
            },
            "dependsOn": [
                "[variables('northeuropeVMNicPIPName')]",
                "[variables('northeuropeVnetResourceId')]",
                "[variables('northeuropeNSGResourceId')]"
            ]
        },
        {
            "type": "Microsoft.Network/networkInterfaces",
            "name": "[variables('eastus2VMNicName')]",
            "apiVersion": "2018-08-01",
            "location": "eastus2",
            "scale": null,
            "properties": {
                "ipConfigurations": [
                    {
                        "name": "ipconfig1",
                        "properties": {
                            "privateIPAddress": "10.2.0.4",
                            "privateIPAllocationMethod": "Static",
                            "publicIPAddress": {
                                "id": "[variables('eastus2VMNicPIPResourceId')]"
                            },
                            "subnet": {
                                "id": "[variables('eastus2SubnetResourceId')]"
                            },
                            "primary": true,
                            "privateIPAddressVersion": "IPv4"
                        }
                    }
                ],
                "enableAcceleratedNetworking": false,
                "enableIPForwarding": false,
                "primary": true,
                "networkSecurityGroup": {
                    "id": "[variables('eastus2NSGResourceId')]"
                }
            },
            "dependsOn": [
                "[variables('eastus2VMNicPIPName')]",
                "[variables('eastus2VnetResourceId')]",
                "[variables('eastus2NSGResourceId')]"
            ]
        },
        {
            "type": "Microsoft.Compute/virtualMachines",
            "name": "[variables('northeuropeVMName')]",
            "apiVersion": "2018-06-01",
            "location": "northeurope",
            "properties": {
                "hardwareProfile": {
                    "vmSize": "Standard_B1s"
                },
                "storageProfile": {
                    "imageReference": {
                        "publisher": "Canonical",
                        "offer": "UbuntuServer",
                        "sku": "18.04-LTS",
                        "version": "latest"
                    },
                    "osDisk": {
                        "osType": "Linux",
                        "name": "[concat(variables('northeuropeVMName'), '-disk')]",
                        "createOption": "FromImage",
                        "caching": "ReadWrite",
                        "managedDisk": {
                            "storageAccountType": "Premium_LRS"
                        },
                        "diskSizeGB": 30
                    },
                    "dataDisks": []
                },
                "osProfile": {
                    "computerName": "[variables('northeuropeVMName')]",
                    "adminUsername": "[parameters('username')]",
                    "adminPassword": "[parameters('password')]",
                    "linuxConfiguration": {
                        "disablePasswordAuthentication": false,
                        "provisionVMAgent": true
                    },
                    "secrets": [],
                    "allowExtensionOperations": true
                },
                "networkProfile": {
                    "networkInterfaces": [
                        {
                            "id": "[variables('northeuropeVMNicResourceId')]"
                        }
                    ]
                },
                "diagnosticsProfile": {
                    "bootDiagnostics": {
                        "enabled": false
                    }
                }
            },
            "resources": [
                {
                    "type": "extensions",
                    "name": "apache-ext",
                    "apiVersion": "2018-10-01",
                    "location": "northeurope",
                    "properties": {
                        "publisher": "Microsoft.Azure.Extensions",
                        "type": "CustomScript",
                        "typeHandlerVersion": "2.0",
                        "autoUpgradeMinorVersion": true,
                        "settings": {
                            "skipDos2Unix": true
                        },
                        "protectedSettings": {
                            "commandToExecute": "sh setup-nginx.sh northeurope",
                            "fileUris": [
                                "[uri(variables('deploymentUrl'), 'setup-nginx.sh')]"
                            ]
                        }
                    },
                    "dependsOn": [
                        "[variables('northeuropeVMName')]"
                    ]
                }
            ],
            "dependsOn": [
                "[variables('northeuropeVMNicName')]"
            ]
        },
        {
            "type": "Microsoft.Compute/virtualMachines",
            "name": "[variables('eastus2VMName')]",
            "apiVersion": "2018-06-01",
            "location": "eastus2",
            "properties": {
                "hardwareProfile": {
                    "vmSize": "Standard_B1s"
                },
                "storageProfile": {
                    "imageReference": {
                        "publisher": "Canonical",
                        "offer": "UbuntuServer",
                        "sku": "18.04-LTS",
                        "version": "latest"
                    },
                    "osDisk": {
                        "osType": "Linux",
                        "name": "[concat(variables('eastus2VMName'), '-disk')]",
                        "createOption": "FromImage",
                        "caching": "ReadWrite",
                        "managedDisk": {
                            "storageAccountType": "Premium_LRS"
                        },
                        "diskSizeGB": 30
                    },
                    "dataDisks": []
                },
                "osProfile": {
                    "computerName": "[variables('eastus2VMName')]",
                    "adminUsername": "[parameters('username')]",
                    "adminPassword": "[parameters('password')]",
                    "linuxConfiguration": {
                        "disablePasswordAuthentication": false,
                        "provisionVMAgent": true
                    },
                    "secrets": [],
                    "allowExtensionOperations": true
                },
                "networkProfile": {
                    "networkInterfaces": [
                        {
                            "id": "[variables('eastus2VMNicResourceId')]"
                        }
                    ]
                },
                "diagnosticsProfile": {
                    "bootDiagnostics": {
                        "enabled": false
                    }
                }
            },
            "resources": [
                {
                    "type": "extensions",
                    "name": "apache-ext",
                    "apiVersion": "2018-10-01",
                    "location": "eastus2",
                    "properties": {
                        "publisher": "Microsoft.Azure.Extensions",
                        "type": "CustomScript",
                        "typeHandlerVersion": "2.0",
                        "autoUpgradeMinorVersion": true,
                        "settings": {
                            "skipDos2Unix": true
                        },
                        "protectedSettings": {
                            "commandToExecute": "sh setup-nginx.sh eastus2",
                            "fileUris": [
                                "[uri(variables('deploymentUrl'), 'setup-nginx.sh')]"
                            ]
                        }
                    },
                    "dependsOn": [
                        "[variables('eastus2VMName')]"
                    ]
                }
            ],
            "dependsOn": [
                "[variables('eastus2VMNicName')]"
            ]
        }
    ],
    "outputs": {}
}